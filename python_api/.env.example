

#NOTE: this is NOT necessary for running the api locally


# Generate a long random string (e.g., using: openssl rand -base64 32)
MY_API_SECRET_KEY=your_super_secret_random_key_here

# SERVER SETTINGS
APP_ENV=local
PORT=5000

# CORS SETTINGS (Comma separated for multiple origins)
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://yourwebsite.com